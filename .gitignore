# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Tesseract language data — downloaded at runtime, do not commit
*.traineddata

# Claude Code local session memory
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block all local credential files
.env*
# but allow the example template (contains no real secrets)
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.next
node_modules
